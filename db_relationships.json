  "relationships": {
    "CONTATOS_ID": {
      "type": "common_key",
      "databases": ["DB1_PODER_AQUISITIVO", "DB2_HISTORICO_TELEFONES", "DB3_CONTATOS"],
      "description": "Chave primária que conecta dados de poder aquisitivo, histórico de telefones e informações de contatos"
    },
    "CPF_DocNumber": {
      "type": "potential_match",
      "databases": ["DB3_CONTATOS", "DB4_IRPF"],
      "fields": {
        "DB3_CONTATOS": "CPF",
        "DB4_IRPF": "DocNumber"
      },
      "description": "Possível relação entre CPF em contatos e DocNumber em IRPF (ambos podem ser CPF)"
    }
  },
  "query_strategies": {
    "by_contatos_id": {
      "description": "Busca completa por CONTATOS_ID retornando dados de 3 bancos",
      "databases": ["DB1_PODER_AQUISITIVO", "DB2_HISTORICO_TELEFONES", "DB3_CONTATOS"]
    },
    "by_cpf": {
      "description": "Busca por CPF retornando dados de contatos e IRPF",
      "databases": ["DB3_CONTATOS", "DB4_IRPF"],
      "note": "Requer normalização de CPF (remover pontos e traços)"
    },
    "full_profile": {
      "description": "Perfil completo: busca por CONTATOS_ID ou CPF e retorna todos os dados disponíveis",
      "databases": ["DB1_PODER_AQUISITIVO", "DB2_HISTORICO_TELEFONES", "DB3_CONTATOS", "DB4_IRPF"]
    }
